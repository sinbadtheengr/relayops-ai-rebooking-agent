{
  "name": "relayops-ai-rebooking-agent",
  "version": "0.1.0",
  "description": "Slack-first AI employee that identifies overdue customers and helps small businesses recover rebooking revenue.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "node --import tsx src/app.ts",
    "dev:watch": "tsx watch src/app.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/app.js",
    "seed": "tsx scripts/seed.ts",
    "scan": "tsx scripts/run-daily-scan.ts",
    "demo:ask": "tsx scripts/demo-query.ts",
    "mcp": "tsx scripts/mcp.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@slack/bolt": "^4.4.0",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^16.4.7",
    "node-cron": "^4.5.0",
    "openai": "^4.85.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.5",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

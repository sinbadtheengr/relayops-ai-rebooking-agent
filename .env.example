# Slack app credentials
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-socket-mode-token
SLACK_SIGNING_SECRET=your-signing-secret

# Optional: post the daily scan here when DAILY_SCAN_ENABLED=true
SLACK_REPORT_CHANNEL_ID=C0123456789
DAILY_SCAN_ENABLED=false
DAILY_SCAN_CRON=0 8 * * 1-6
TIMEZONE=America/Toronto

# OpenAI is optional for local demos; without it RelayOps uses deterministic templates.
OPENAI_API_KEY=sk-your-key
OPENAI_MODEL=gpt-4o-mini

# Storage
DATABASE_URL=./data/relayops.db
PUBLIC_APP_URL=https://example.ngrok-free.app
